# Copy this file to .env and fill in your real values.
# The .env file is gitignored, so your real keys never get committed.

# Required for Phase 3 (LLM integration). Not needed for Phase 1.
ANTHROPIC_API_KEY=your_key_here

# Required for Phase 2 (GitHub integration). Not needed for Phase 1.
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_token_here

# Optional. Controls log verbosity. One of: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO